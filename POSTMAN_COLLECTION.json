              "mode": "raw",
              "raw": "{\n  \"projectId\": 1,\n  \"buildNumber\": \"123\",\n  \"status\": \"SUCCESS\",\n  \"duration\": 300,\n  \"branch\": \"main\",\n  \"commitId\": \"abc123def456789\",\n  \"logs\": \"Build completed successfully\",\n  \"triggeredBy\": \"webhook\"\n}"
